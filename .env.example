# NeuroNews offline-first configuration
# Copy this file to .env and adjust values as needed.
# No cloud account or remote credentials are required.

# =============================================================================
# Core data store
# =============================================================================

# Path to the local DuckDB warehouse file (default: data/neuronews.duckdb)
# NEURONEWS_DB_PATH=data/neuronews.duckdb

# =============================================================================
# API / app behaviour
# =============================================================================

# Enable dev-mode shortcuts (disables WAF, rate limiting, auth middleware).
# Set to "true" for local frontend development.
# NEURONEWS_DEV_MODE=false

# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
# NEURONEWS_LOG_LEVEL=INFO

# =============================================================================
# Encryption / backups (Issue #62)
# =============================================================================

# Passphrase for encrypted DuckDB backups (scripts/backup_db.py).
# NEURONEWS_BACKUP_KEY=change-me

# Passphrase for encrypted KG exports (scripts/export_kg.py).
# NEURONEWS_KG_EXPORT_KEY=change-me

# =============================================================================
# Embedding models (Issue #228)
# =============================================================================

# Embedding provider: "local" (default) or "openai"
EMBEDDING_PROVIDER=local

# Local model name (from sentence-transformers)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Additional embedding configuration
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_RETRIES=3
EMBEDDING_DETERMINISTIC_SEED=42

# Cache directory for local models (optional)
# NEURONEWS_MODEL_DIR=/path/to/models
# EMBEDDING_CACHE_DIR=/tmp/embeddings_cache

# =============================================================================
# Vector backend (Issue #239)
# =============================================================================

# Choose your vector backend: 'qdrant' or 'pgvector'
# VECTOR_BACKEND=pgvector

# Qdrant (when VECTOR_BACKEND=qdrant)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# =============================================================================
# Local service emulators (optional, for scraper/pipeline integration)
# =============================================================================

# Local S3-compatible endpoint (MinIO default: http://localhost:9000)
# S3_ENDPOINT_URL=http://localhost:9000

# Local DynamoDB endpoint (DynamoDB Local default: http://localhost:8000)
# DYNAMODB_ENDPOINT_URL=http://localhost:8000

# AWS region used by local emulators
# AWS_REGION=us-east-1

# PostgreSQL for local pipeline state (if needed alongside DuckDB)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=neuronews
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password
