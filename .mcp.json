{
  "mcpServers": {
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {}
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp"
      ],
      "env": {}
    },
    "postgres": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://neuronews:neuronews_vector_pass@localhost:5433/neuronews_vector"
      ],
      "env": {}
    },
    "neuronews-pipeline": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "tools/pipeline_mcp/server.py"
      ],
      "env": {}
    },
    "neuronews-contracts": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "tools/contract_mcp/server.py"
      ],
      "env": {}
    },
    "neuronews-lineage": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "tools/lineage_mcp/server.py"
      ],
      "env": {}
    }
  }
}